# --- Server ---
PORT=8080
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.example.com

# --- Database ---
# DB_DRIVER: "sqlite" (default, file-based, good for local/dev/demo) or "postgres" (managed cloud DB)
DB_DRIVER=postgres

# Only used when DB_DRIVER=sqlite
SQLITE_PATH=./data/contacts.db

# Only used when DB_DRIVER=postgres. Standard libpq connection string.
# Never commit a real value here — inject via your platform's secret manager
# (AWS Secrets Manager / SSM Parameter Store, Azure Key Vault, GCP Secret Manager,
# or the equivalent environment-variable injection of your container platform).
# Example: postgresql://appuser:CHANGE_ME@your-db-host:5432/contacts?sslmode=require
DATABASE_URL=
