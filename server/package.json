{
  "name": "contacts-api",
  "version": "1.0.0",
  "description": "Contacts Manager REST API",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --no-warnings src/index.js",
    "dev": "node --no-warnings --watch src/index.js",
