# Base URL of the Contacts API. In local dev, leave this unset and the Vite
# dev server proxy (vite.config.js) forwards /api to VITE_DEV_API_PROXY_TARGET.
# In production builds, set this to the deployed API's public URL, e.g.
# https://contacts-api.yourdomain.com/api
VITE_API_BASE_URL=/api

# Only used by the local Vite dev server's proxy, not bundled into the build.
VITE_DEV_API_PROXY_TARGET=http://localhost:8080
